{
  "name": "@cuzfrog/jie",
  "version": "0.2.0",
  "workspaces": ["packages/*"],
  "catalog": {
    "typescript": "5.9.3",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "@types/react": "18.3.12",
    "@earendil-works/pi-agent-core": "0.79.1",
    "@earendil-works/pi-ai": "0.79.1",
    "typebox": "1.1.38",
    "yaml": "2.9.0",
    "ulid": "2.3.0",
    "node-html-parser": "6.1.13",
    "chalk": "5.6.2",
    "ink": "5.2.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ink-testing-library": "4.0.0"
  },
  "bin": {
    "jie": "packages/jie-cli/index.ts"
  },
  "scripts": {
    "mock:start": "bun run packages/mock-llm-backend/server.ts",
    "test:e2e:local": "set -a && . ./setenv && set +a && bun test --timeout=60000 tests/e2e",
    "test:e2e:mock": "JIE_E2E_BASE_URL=http://localhost:12346 JIE_E2E_API_KEY=dummy JIE_E2E_MODEL=dummy bun test --max-concurrency=1 tests/e2e"
  },
  "dependencies": {
    "@cuzfrog/jie-platform": "workspace:*",
    "@cuzfrog/jie-tui": "workspace:*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "catalog:",
    "@earendil-works/pi-ai": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typebox": "catalog:"
  }
}
