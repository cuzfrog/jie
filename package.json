{
  "name": "@cuzfrog/jie",
  "version": "0.2.0",
  "workspaces": ["packages/*"],
  "bin": {
    "jie": "packages/jie-cli/index.ts"
  },
  "scripts": {
    "mock:start": "bun run tests/mock-llm-backend/server.ts",
    "test:e2e:local": "set -a && . ./setenv && set +a && bun test tests/e2e",
    "test:e2e:mock": "JIE_E2E_BASE_URL=http://localhost:12346 JIE_E2E_API_KEY=dummy JIE_E2E_MODEL=dummy bun test tests/e2e/cli"
  },
  "dependencies": {
    "@cuzfrog/jie-platform": "workspace:*",
    "@cuzfrog/jie-tui": "workspace:*",
    "@earendil-works/pi-tui": "0.79.10"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.79.1",
    "@earendil-works/pi-ai": "0.79.1",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "@xterm/headless": "5.5.0",
    "typebox": "1.1.38"
  }
}
