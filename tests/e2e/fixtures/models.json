{
  "providers": {
    "e2e": {
      "baseUrl": "${JIE_E2E_BASE_URL}",
      "api": "openai-completions",
      "apiKey": "${JIE_E2E_API_KEY}",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "${JIE_E2E_MODEL}",
          "name": "${JIE_E2E_MODEL}",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 128000,
          "maxTokens": 16384,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        }
      ]
    }
  }
}
